{
  "expo": {
    "name": "La Cielo",
    "slug": "lacaselo-app",
    "scheme": "lacaselo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B3D2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lacaselo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B3D2E"
      },
      "package": "com.lacaselo.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61d81797-1bc9-49b9-a375-7fe3d77e2acc"
      }
    }
  }
}
